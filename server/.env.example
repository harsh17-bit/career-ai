PORT=5000
MONGO_URI=mongodb://localhost:27017/career-ai
JWT_SECRET=super_secret_key_change_me
GEMINI_API_KEY=your_gemini_key_here
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Email (Google App Password)
# Use your full Gmail address for EMAIL_USER
# Use a 16-character Google App Password for GOOGLE_APP_PASSWORD
EMAIL_USER=your_email@gmail.com
GOOGLE_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM=CareerAI <your_email@gmail.com>

# Optional overrides (defaults work for Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
