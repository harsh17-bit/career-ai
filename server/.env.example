# SMTP credentials
EMAIL_USER=your-email@example.com
# or alternate names accepted by mailer
SMTP_USER=your-email@example.com
GOOGLE_APP_PASSWORD=your-app-password-or-smtp-pass
SMTP_PASS=your-smtp-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
EMAIL_FROM="CareerAI <no-reply@careerai.com>"

# App URLs (used in email templates)
APP_URL=https://app.careerai.com
SUPPORT_URL=https://careerai.com/support

# Optional: test recipient for quick runs
TEST_EMAIL=recipient@example.com
PORT=5000
MONGO_URI=mongodb://localhost:27017/career-ai
JWT_SECRET=super_secret_key_change_me
GEMINI_API_KEY=your_gemini_key_here
CLIENT_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your_google_oauth_client_id
NODE_ENV=development

# Email (Google App Password)
# Use your full Gmail address for EMAIL_USER
# Use a 16-character Google App Password for GOOGLE_APP_PASSWORD
EMAIL_USER=your_email@gmail.com
GOOGLE_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM=CareerAI <your_email@gmail.com>

# Optional overrides (defaults work for Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
